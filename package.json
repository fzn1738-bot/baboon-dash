{
  "name": "baboon-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "tsc && vite build && esbuild server.ts --bundle --platform=node --outfile=server.mjs --format=esm --packages=external",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "node server.mjs"
  },
  "dependencies": {
    "@eslint/js": "^10.0.1",
    "@google-cloud/firestore": "^8.3.0",
    "@google/genai": "^1.45.0",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "esbuild": "^0.27.4",
    "express": "^5.2.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "globals": "^17.4.0",
    "http-proxy-middleware": "^3.0.5",
    "lucide-react": "^0.344.0",
    "playwright": "^1.58.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^9.0.1",
    "resend": "^6.9.4",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.57.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^5.0.6",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.2.2",
    "vite": "^5.2.0"
  }
}
