{
  "name": "baboon-dashboard",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "check:users-boundary": "node scripts/check-users-boundary.cjs",
    "build": "tsc && vite build && esbuild server.ts --bundle --platform=node --outfile=server.mjs --format=esm --packages=external",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "start": "node server.mjs"
  },
  "dependencies": {
    "@eslint/js": "^9.14.0",
    "@google-cloud/firestore": "^7.10.0",
    "@google/generative-ai": "^0.21.0",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.3.1",
    "esbuild": "^0.24.0",
    "express": "^4.21.1",
    "firebase": "^11.0.2",
    "firebase-admin": "^12.7.0",
    "globals": "^15.12.0",
    "http-proxy-middleware": "^3.0.3",
    "lucide-react": "^0.456.0",
    "playwright": "^1.48.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "resend": "^4.0.1",
    "tsx": "^4.19.2",
    "typescript-eslint": "^8.14.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.14",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
